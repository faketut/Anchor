# Splunk connection
# Matches docker-compose.yml defaults; change if you run a different instance.
# For Alibaba Cloud deployment: set SPLUNK_HOST=<ecs-public-ip> and ensure
# port 8089 is open in the ECS security group to your client IP only.
# See deploy/alibaba-cloud.md.
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=Anchor!Demo2026
SPLUNK_SCHEME=https
SPLUNK_VERIFY_SSL=false

# KV Store app context (collections live inside an app)
ANCHOR_APP=search
ANCHOR_OWNER=nobody

# LLM provider: "qwen" | "gemini" | "splunk"
ANCHOR_LLM=qwen

# Qwen (DashScope OpenAI-compatible endpoint)
# https://help.aliyun.com/zh/model-studio/developer-reference/compatibility-of-openai-with-dashscope
QWEN_API_KEY=sk-...
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Gemini (OpenAI-compatible endpoint)
# https://ai.google.dev/gemini-api/docs/openai
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Splunk-hosted model (placeholder — wire when available)
SPLUNK_LLM_ENDPOINT=
SPLUNK_LLM_MODEL=

# ---------------------------------------------------------------------------
# Alibaba Cloud OSS (only needed on the ECS host running backup_kv_to_oss.py)
# ---------------------------------------------------------------------------
# OSS_ACCESS_KEY_ID=LTAI...
# OSS_ACCESS_KEY_SECRET=
# OSS_ENDPOINT=oss-ap-southeast-1.aliyuncs.com
# OSS_BUCKET=anchor-memory-backups-<your-suffix>
